# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
# RentCast property-data API — https://app.rentcast.io  (Dashboard → API Keys)
# Setting this auto-activates the live RentCast address->build-year adapter in
# server.js. Leave it blank and the server falls back to the bundled MockProvider.
RENTCAST_API_KEY=

# Supabase persistence — POST /intelligence appends a row to house_intelligence_requests.
# Use the PUBLISHABLE (anon) key (RLS-gated), NOT the secret/service_role key.
# Set BOTH to enable persistence; leave blank and the server uses a no-op echo store.
# In production, set these as platform env vars — do NOT commit real values here.
SUPABASE_URL=
SUPABASE_KEY=