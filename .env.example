# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
# RentCast property-data API — https://app.rentcast.io  (Dashboard → API Keys)
# Setting this auto-activates the live RentCast address->build-year adapter in
# server.js. Leave it blank and the server falls back to the bundled MockProvider.
RENTCAST_API_KEY=

# Supabase persistence — POST /intelligence appends a row to house_intelligence_requests.
# Use the PUBLISHABLE (anon) key (RLS-gated), NOT the secret/service_role key.
# Set BOTH to enable persistence; leave blank and the server uses a no-op echo store.
# In production, set these as platform env vars — do NOT commit real values here.
SUPABASE_URL=
SUPABASE_KEY=

# Material Takeoff — LIVE Home Depot pricing (material-takeoff service).
# Home Depot has NO official public pricing API, so live prices come from a THIRD-PARTY
# service (e.g. SerpApi's Home Depot engine, or BigBox). Set the key to enable the
# pricing + profit layout (POST /material-takeoff?price=true). Leave blank and pricing
# is UNAVAILABLE — there is no baked price catalog (quantities still return fine).
HOMEDEPOT_API_KEY=
# Optional: override the pricing endpoint. Defaults to SerpApi's Home Depot engine.
# Supports {query} and {key} placeholders for non-SerpApi providers, e.g.:
#   https://api.bigboxapi.com/request?api_key={key}&type=search&search_term={query}
HOMEDEPOT_API_URL=
# Dev/test ONLY: set PRICING_MOCK=1 to use deterministic fake prices with no key/network.
# NEVER set this in production — it is not a real price source.
PRICING_MOCK=